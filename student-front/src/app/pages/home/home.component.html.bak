<!-- ══════════════════════════════════════════
     Course Details Modal
══════════════════════════════════════════ -->
<div *ngIf="activeCourse()"
     class="fixed inset-0 z-[90] flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" (click)="closeDetails()"></div>
  <div class="relative z-10 bg-white dark:bg-[#162033] rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden flex flex-col" style="max-height:85vh">

    <!-- Header -->
    <div class="flex items-center justify-between p-5 border-b border-[#DDE1EA] dark:border-slate-800 flex-shrink-0">
      <div class="flex items-center gap-2">
        <button *ngIf="activeSession()" (click)="backToSessions()"
                class="w-7 h-7 rounded-full bg-[#F5F6FA] dark:bg-white/10 flex items-center justify-center hover:bg-[#DDE1EA] transition-all ml-1">
          <span class="material-symbols-outlined text-[#183764] dark:text-white" style="font-size:16px">arrow_forward</span>
        </button>
        <div>
          <h3 class="font-bold text-base text-[#183764] dark:text-white">
            {{ activeSession() ? activeSession().title : activeCourse()?.title }}
          </h3>
          <p class="text-xs text-[#8892a0] mt-0.5">
            {{ activeSession() ? activeCourse()?.title : (activeCourse()?.teacherName || activeCourse()?.teacher?.fullName) }}
          </p>
        </div>
      </div>
      <button (click)="closeDetails()"
              class="w-8 h-8 rounded-full bg-[#F5F6FA] dark:bg-white/10 flex items-center justify-center hover:bg-[#DDE1EA] transition-all flex-shrink-0">
        <span class="material-symbols-outlined text-[#183764] dark:text-white" style="font-size:18px">close</span>
      </button>
    </div>

    <!-- Body: Sessions list -->
    <div *ngIf="!activeSession()" class="overflow-y-auto flex-1 p-5">
      <div *ngIf="loadingSessions()" class="flex justify-center py-8">
        <span class="material-symbols-outlined animate-spin text-[#8892a0]">refresh</span>
      </div>
      <div *ngIf="!loadingSessions() && activeCourseSessions().length > 0" class="space-y-2">
        <div *ngFor="let s of activeCourseSessions(); let i = index"
             (click)="openSession(s)"
             class="flex items-center gap-3 p-3 rounded-xl border border-[#DDE1EA] dark:border-slate-800 hover:bg-[#F5F6FA] dark:hover:bg-white/5 transition-colors cursor-pointer group">
          <div class="w-8 h-8 rounded-lg bg-[#e8edf7] dark:bg-white/5 flex items-center justify-center flex-shrink-0 text-xs font-bold text-[#183764] dark:text-white">
            {{ i + 1 }}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-[#183764] dark:text-white truncate">{{ s.title }}</p>
            <p *ngIf="s.description" class="text-xs text-[#8892a0] truncate mt-0.5">{{ s.description }}</p>
          </div>
          <span class="material-symbols-outlined text-[#DDE1EA] group-hover:text-[#183764] dark:group-hover:text-white transition-colors flex-shrink-0" style="font-size:16px">chevron_left</span>
        </div>
      </div>
      <div *ngIf="!loadingSessions() && activeCourseSessions().length === 0"
           class="flex flex-col items-center py-8 text-[#8892a0]">
        <span class="material-symbols-outlined" style="font-size:40px">play_circle</span>
        <p class="mt-2 text-sm">لا توجد محاضرات متاحة حالياً</p>
      </div>
    </div>

    <!-- Body: Session contents (weeks) -->
    <div *ngIf="activeSession()" class="overflow-y-auto flex-1 p-5 space-y-4">
      <div *ngIf="weeksLoading()" class="flex justify-center py-8">
        <span class="material-symbols-outlined animate-spin text-[#8892a0]">refresh</span>
      </div>
      <div *ngIf="sessionAccessError()" class="flex flex-col items-center py-8 text-red-400">
        <span class="material-symbols-outlined" style="font-size:40px">lock</span>
        <p class="mt-2 text-sm">يجب الاشتراك للوصول لهذا المحتوى</p>
      </div>
      <div *ngFor="let week of weekContents()" class="space-y-2">
        <div class="flex items-center gap-2 mb-1">
          <div class="w-1 h-4 bg-[#183764] dark:bg-blue-400 rounded-full"></div>
          <span class="text-xs font-black text-[#183764] dark:text-white uppercase tracking-wide">{{ week.title }}</span>
        </div>
        <div *ngIf="week.loading" class="flex justify-center py-3">
          <span class="material-symbols-outlined animate-spin text-[#8892a0]" style="font-size:18px">refresh</span>
        </div>
        <div *ngIf="!week.loading">
          <div *ngIf="week.materials.length === 0 && week.quizzes.length === 0 && week.assignments.length === 0"
               class="text-xs text-[#8892a0] text-center py-2">لا يوجد محتوى بعد</div>
          <div class="space-y-1.5">
            <div *ngFor="let m of week.materials"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-[#F5F6FA] dark:bg-white/5">
              <span class="material-symbols-outlined flex-shrink-0" [ngClass]="matColor(m.materialType)" style="font-size:20px">{{ matIcon(m.materialType) }}</span>
              <span class="flex-1 text-xs font-medium text-[#183764] dark:text-white truncate">{{ m.fileName || m.title || 'ملف' }}</span>
              <span *ngIf="m.durationSeconds" class="text-[10px] text-[#8892a0] flex-shrink-0">{{ formatDuration(m.durationSeconds) }}</span>
            </div>
            <div *ngFor="let q of week.quizzes"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-[#fff8f0] dark:bg-[#F59239]/10">
              <span class="material-symbols-outlined text-[#F59239] flex-shrink-0" style="font-size:20px">quiz</span>
              <span class="flex-1 text-xs font-medium text-[#183764] dark:text-white truncate">{{ q.title }}</span>
            </div>
            <div *ngFor="let a of week.assignments"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-[#f0f7ff] dark:bg-blue-500/10">
              <span class="material-symbols-outlined text-blue-500 flex-shrink-0" style="font-size:20px">assignment</span>
              <span class="flex-1 text-xs font-medium text-[#183764] dark:text-white truncate">{{ a.title }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="p-5 border-t border-[#DDE1EA] dark:border-slate-800 flex flex-col gap-3 flex-shrink-0">
      <span *ngIf="enrollFreeError()" class="text-red-500 text-xs text-center">{{ enrollFreeError() }}</span>
      <div class="flex gap-3">
        <button *ngIf="!isEnrolled(activeCourse()?.id) && activeCourse()?.price > 0"
                (click)="openPayment(activeCourse(), $event)"
                class="flex-1 bg-[#F59239] text-white py-2.5 rounded-xl font-bold text-sm hover:opacity-90 transition-all">
          اشترك الآن
        </button>
        <button *ngIf="!isEnrolled(activeCourse()?.id) && !(activeCourse()?.price > 0)"
                (click)="enrollFree(activeCourse(), $event)"
                class="flex-1 bg-[#4BBBA0] text-white py-2.5 rounded-xl font-bold text-sm hover:opacity-90 transition-all">
          اشترك مجاناً
        </button>
        <button *ngIf="isEnrolled(activeCourse()?.id)"
                (click)="goToCourse(activeCourse(), $event)"
                class="flex-1 bg-[#183764] text-white py-2.5 rounded-xl font-bold text-sm hover:opacity-90 transition-all">
          الدخول للكورس
        </button>
        <button (click)="closeDetails()"
                class="px-5 py-2.5 rounded-xl border border-[#DDE1EA] dark:border-slate-800 text-[#183764] dark:text-white text-sm font-bold hover:bg-[#F5F6FA] dark:hover:bg-white/5 transition-all">
          إغلاق
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     Payment Modal
══════════════════════════════════════════ -->
<div *ngIf="paymentCourse()"
     class="fixed inset-0 z-[100] flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" (click)="closePayment()"></div>
  <div class="relative z-10 bg-white dark:bg-[#162033] rounded-2xl w-full max-w-md shadow-2xl overflow-hidden">
    <div class="flex items-center justify-between p-5 border-b border-[#DDE1EA] dark:border-slate-800">
      <div>
        <h3 class="font-bold text-base text-[#183764] dark:text-white">الاشتراك في الكورس</h3>
        <p class="text-xs text-[#8892a0] mt-0.5">{{ paymentCourse()?.title }}</p>
      </div>
      <button (click)="closePayment()"
              class="w-8 h-8 rounded-full bg-[#F5F6FA] dark:bg-white/10 flex items-center justify-center hover:bg-[#DDE1EA] transition-all">
        <span class="material-symbols-outlined text-[#183764] dark:text-white" style="font-size:18px">close</span>
      </button>
    </div>

    <div *ngIf="paymentSuccess()" class="p-8 flex flex-col items-center text-center gap-3">
      <div class="w-16 h-16 rounded-full bg-[#e6f7f4] flex items-center justify-center text-3xl">🎉</div>
      <p class="font-bold text-[#183764] dark:text-white text-lg">{{ paymentSuccess() }}</p>
    </div>

    <div *ngIf="!paymentSuccess() && paymentStep() === 'choose'" class="p-5 space-y-3">
      <p class="text-sm text-[#8892a0] text-center mb-2">اختر طريقة الدفع</p>
      <div *ngIf="paymentCourse()?.price" class="text-center mb-3">
        <span class="text-2xl font-black text-[#183764] dark:text-white">{{ paymentCourse()?.price | number }}</span>
        <span class="text-sm text-[#8892a0] mr-1">EGP</span>
      </div>
      <button (click)="selectWallet()"
              class="w-full flex items-center gap-4 p-4 rounded-xl border-2 border-[#DDE1EA] dark:border-slate-800 hover:border-[#183764] transition-all group">
        <div class="w-12 h-12 rounded-xl bg-[#e8edf7] dark:bg-white/10 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-[#183764] dark:text-white">account_balance_wallet</span>
        </div>
        <div class="text-right flex-1">
          <p class="font-bold text-[#183764] dark:text-white text-sm">المحفظة الرقمية</p>
          <p class="text-xs text-[#8892a0]">ادفع من رصيدك الحالي</p>
        </div>
        <span class="material-symbols-outlined text-[#8892a0] group-hover:text-[#183764] transition-colors">chevron_left</span>
      </button>
      <button (click)="paymentStep.set('code'); paymentError.set('')"
              class="w-full flex items-center gap-4 p-4 rounded-xl border-2 border-[#DDE1EA] dark:border-slate-800 hover:border-[#4BBBA0] transition-all group">
        <div class="w-12 h-12 rounded-xl bg-[#e6f7f4] dark:bg-[#4BBBA0]/10 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-[#4BBBA0]">key</span>
        </div>
        <div class="text-right flex-1">
          <p class="font-bold text-[#183764] dark:text-white text-sm">كود الوصول</p>
          <p class="text-xs text-[#8892a0]">ادخل كود مكون من 11 حرف (XXXXX-XXXXX)</p>
        </div>
        <span class="material-symbols-outlined text-[#8892a0] group-hover:text-[#4BBBA0] transition-colors">chevron_left</span>
      </button>
      <button (click)="paymentStep.set('online'); paymentError.set('')"
              class="w-full flex items-center gap-4 p-4 rounded-xl border-2 border-[#DDE1EA] dark:border-slate-800 hover:border-[#F59239] transition-all group">
        <div class="w-12 h-12 rounded-xl bg-amber-50 dark:bg-[#F59239]/10 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-[#F59239]">credit_card</span>
        </div>
        <div class="text-right flex-1">
          <p class="font-bold text-[#183764] dark:text-white text-sm">الدفع الأونلاين</p>
          <p class="text-xs text-[#8892a0]">فيزا · فوري · فودافون كاش · إنستاباي</p>
        </div>
        <span class="material-symbols-outlined text-[#8892a0] group-hover:text-[#F59239] transition-colors">chevron_left</span>
      </button>
    </div>

    <div *ngIf="!paymentSuccess() && paymentStep() === 'wallet'" class="p-5 space-y-3">
      <div *ngIf="walletLoading()" class="flex justify-center py-6">
        <span class="material-symbols-outlined animate-spin text-[#183764]">refresh</span>
      </div>
      <div *ngIf="!walletLoading()" class="space-y-3">
        <div class="bg-[#F5F6FA] dark:bg-white/5 rounded-xl p-4 flex items-center justify-between">
          <span class="text-sm text-[#8892a0]">رصيدك الحالي</span>
          <span class="font-black text-[#183764] dark:text-white">{{ walletBalanceVal() | number }} EGP</span>
        </div>
        <div class="bg-[#F5F6FA] dark:bg-white/5 rounded-xl p-4 flex items-center justify-between">
          <span class="text-sm text-[#8892a0]">سعر الكورس</span>
          <span class="font-black text-[#183764] dark:text-white">{{ paymentCourse()?.price | number }} EGP</span>
        </div>
        <div *ngIf="paymentError()" class="text-xs text-red-500 text-center">{{ paymentError() }}</div>
      </div>
    </div>

    <div *ngIf="!paymentSuccess() && paymentStep() === 'code'" class="p-5 space-y-4">
      <label class="block text-sm font-bold text-[#183764] dark:text-white">أدخل كود الوصول</label>
      <input [value]="accessCodeInput()"
             (input)="accessCodeInput.set($any($event.target).value.toUpperCase())"
             type="text" placeholder="XXXXX-XXXXX" maxlength="11"
             class="w-full border-2 border-[#DDE1EA] dark:border-slate-700 rounded-xl px-4 py-3 text-center text-lg font-mono font-bold tracking-widest bg-white dark:bg-white/5 text-[#183764] dark:text-white focus:border-[#4BBBA0] focus:outline-none"
             style="direction:ltr">
      <p class="text-xs text-[#8892a0] text-center">الكود مكون من 11 حرف بالصيغة: ABCDE-FGHIJ</p>
      <div *ngIf="paymentError()" class="text-xs text-red-500 text-center">{{ paymentError() }}</div>
    </div>

    <div *ngIf="!paymentSuccess() && paymentStep() === 'online'" class="p-5 space-y-4">
      <div class="bg-[#F5F6FA] dark:bg-white/5 rounded-xl p-4 text-center space-y-2">
        <span class="material-symbols-outlined text-[#F59239]" style="font-size:40px">open_in_new</span>
        <p class="text-sm font-bold text-[#183764] dark:text-white">ستنتقل لصفحة الدفع الآمنة</p>
        <p class="text-xs text-[#8892a0]">بوابة فواتيرك — فيزا، فوري، فودافون كاش، إنستاباي</p>
        <p class="text-lg font-black text-[#183764] dark:text-white pt-1">{{ paymentCourse()?.price | number }} EGP</p>
      </div>
      <div *ngIf="paymentError()" class="text-xs text-red-500 text-center">{{ paymentError() }}</div>
    </div>

    <div *ngIf="!paymentSuccess()" class="p-5 border-t border-[#DDE1EA] dark:border-slate-800 flex gap-3">
      <button *ngIf="paymentStep() !== 'choose'"
              (click)="paymentStep.set('choose'); paymentError.set('')"
              class="px-4 py-2.5 rounded-xl border border-[#DDE1EA] dark:border-slate-800 text-[#183764] dark:text-white text-sm font-bold hover:bg-[#F5F6FA] dark:hover:bg-white/5 transition-all">
        رجوع
      </button>
      <button *ngIf="paymentStep() === 'wallet'"
              (click)="confirmWalletPay()"
              [disabled]="paymentLoading() || walletLoading()"
              class="flex-1 bg-[#183764] text-white py-2.5 rounded-xl font-bold text-sm hover:opacity-90 transition-all disabled:opacity-50">
        {{ paymentLoading() ? 'جاري الدفع...' : 'تأكيد الدفع' }}
      </button>
      <button *ngIf="paymentStep() === 'code'"
              (click)="redeemCode()"
              [disabled]="paymentLoading() || accessCodeInput().length < 11"
              class="flex-1 bg-[#4BBBA0] text-white py-2.5 rounded-xl font-bold text-sm hover:opacity-90 transition-all disabled:opacity-50">
        {{ paymentLoading() ? 'جاري التحقق...' : 'تفعيل الكود' }}
      </button>
      <button *ngIf="paymentStep() === 'online'"
              (click)="payOnline()"
              [disabled]="paymentLoading()"
              class="flex-1 bg-[#F59239] text-white py-2.5 rounded-xl font-bold text-sm hover:opacity-90 transition-all disabled:opacity-50">
        {{ paymentLoading() ? 'جاري التحويل...' : 'انتقل للدفع' }}
      </button>
    </div>
  </div>
</div>

<!-- ── Prayer Modal ── -->
<div *ngIf="showPrayerModal()"
     class="fixed inset-0 z-[100] flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"
       (click)="showPrayerModal.set(false)"></div>
  <div class="relative z-10 bg-white dark:bg-[#162033] rounded-3xl p-8 max-w-sm w-full text-center shadow-2xl">
    <div class="w-20 h-20 bg-[#e8edf7] dark:bg-white/5 rounded-full flex items-center justify-center mx-auto mb-5">
      <span class="material-symbols-outlined text-[#F59239]"
            style="font-size:48px;font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24">mosque</span>
    </div>
    <h3 class="text-xl font-bold text-[#183764] dark:text-white mb-2">حان موعد {{ prayerName() }}</h3>
    <p class="text-[#8892a0] text-sm mb-6">"أَقِمِ الصَّلَاةَ لِدُلُوكِ الشَّمْسِ إِلَى غَسَقِ اللَّيْلِ"</p>
    <button (click)="showPrayerModal.set(false)"
            class="w-full bg-[#183764] text-white py-3 rounded-xl font-bold hover:bg-[#0f2548] transition-all">
      تقبّل الله منا ومنكم
    </button>
  </div>
</div>

<!-- Loading -->
<div *ngIf="loading()" class="flex justify-center py-20">
  <div class="flex items-center gap-2 text-[#8892a0]">
    <span class="material-symbols-outlined animate-spin">refresh</span> جاري التحميل...
  </div>
</div>

<div *ngIf="!loading()" class="space-y-4">

  <!-- ── Announcements ── -->
  <div *ngIf="announcements().length > 0"
       class="bg-[#FFF8EE] dark:bg-[#2a1f00] border border-[#F59239]/30 rounded-2xl px-5 py-4 flex items-start gap-3">
    <span class="material-symbols-outlined text-[#F59239] flex-shrink-0 mt-0.5"
          style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24">campaign</span>
    <div class="flex-1 min-w-0 space-y-1.5">
      <p *ngFor="let a of announcements()" class="text-sm font-semibold text-[#183764] dark:text-white truncate">
        📢 {{ a.title }} <span class="text-[#8892a0] font-normal">— {{ a.content || a.message }}</span>
      </p>
    </div>
  </div>

  <!-- ══════════════════════════════════
       ROW 1: Teacher Card + Welcome
  ══════════════════════════════════ -->
  <!-- ══ ROW 1: Welcome (left) + Teacher (right) ══ -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-4">

    <!-- Welcome card — left -->
    <div class="lg:col-span-3 bg-white dark:bg-[#162033] border border-[#DDE1EA] dark:border-slate-800 rounded-2xl p-6 md:p-7 relative overflow-hidden">
      <div class="absolute -top-16 -left-16 w-48 h-48 bg-[#183764]/5 rounded-full blur-3xl pointer-events-none dark:opacity-10"></div>
      <div class="relative z-10">
        <div class="flex flex-wrap gap-2 mb-4">
          <span *ngIf="studyTypeLabel"
                class="px-3 py-1 rounded-full text-xs font-bold"
                [class]="studentOnline() ? 'bg-[#e6f7f4] text-[#4BBBA0]' : 'bg-[#e8edf7] text-[#183764]'">
            {{ studyTypeLabel }}
          </span>
          <span *ngIf="studentGrade()"
                class="px-3 py-1 bg-[#e8edf7] dark:bg-white/10 text-[#183764] dark:text-white/80 rounded-full text-xs font-bold">
            {{ studentGrade() }}
          </span>
          <span *ngIf="studentCenter()"
                class="px-3 py-1 bg-[#e6f7f4] dark:bg-[#4BBBA0]/10 text-[#4BBBA0] rounded-full text-xs font-bold">
            {{ studentCenter() }}
          </span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-[#183764] dark:text-white mb-2">
          أهلاً يا {{ studentName() }} 👋
        </h2>
        <p class="text-sm text-[#8892a0] mb-5 max-w-sm">استعد ليوم دراسي حافل. منصتك في انتظارك.</p>

        <!-- Streak — above progress bar -->
        <div class="inline-flex items-center gap-3 bg-[#FFF4E6] dark:bg-[#F59239]/15 border border-[#F59239]/30 rounded-2xl px-5 py-3 mb-4 shadow-sm">
          <span class="text-3xl font-black text-[#F59239] leading-none">{{ streak() }}</span>
          <span class="text-2xl leading-none">🔥</span>
          <div class="flex flex-col">
            <span class="text-xs font-black text-[#F59239]">يوم متتالي</span>
            <span class="text-[10px] text-[#8892a0] font-medium">استمر!</span>
          </div>
        </div>

        <div *ngIf="stats()?.averageProgress != null"
             class="bg-[#F5F6FA] dark:bg-white/5 rounded-xl p-4 max-w-xs">
          <div class="flex justify-between items-center mb-2">
            <span class="text-xs font-bold text-[#183764] dark:text-white">متوسط تقدمك الكلي</span>
            <span class="text-xs font-bold text-[#4BBBA0]">{{ avgProgress }}</span>
          </div>
          <div class="w-full bg-[#DDE1EA] dark:bg-slate-700 rounded-full h-2 overflow-hidden">
            <div class="h-2 rounded-full" style="background:linear-gradient(90deg,#4BBBA0,#183764)"
                 [style.width]="avgProgressNum + '%'"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Teacher card — right -->
    <div *ngIf="teacher()"
         class="lg:col-span-2 rounded-2xl overflow-hidden flex flex-col relative"
         style="min-height:220px">

      <!-- ① Logo bar (top) -->
      <div *ngIf="teacherLogoUrl"
           class="flex items-center justify-center bg-white dark:bg-[#162033] border-b border-[#DDE1EA] dark:border-slate-800 px-4 py-3 flex-shrink-0">
        <img [src]="teacherLogoUrl" alt="logo" class="h-10 max-w-[160px] object-contain">
      </div>

      <!-- ② Card image (main body) — full bleed -->
      <div class="flex-1 relative overflow-hidden"
           [style.background]="teacherHomeCardImage ? 'none' : 'linear-gradient(145deg,#2a1060,#1a0a40)'">

        <!-- If teacher uploaded a full design image -->
        <img *ngIf="teacherHomeCardImage" [src]="teacherHomeCardImage" alt=""
             class="w-full h-full object-cover absolute inset-0">

        <!-- Fallback: animated purple card with avatar -->
        <div *ngIf="!teacherHomeCardImage" class="relative w-full h-full flex items-end justify-between p-6 pb-7" style="min-height:180px">
          <div class="absolute top-4 right-8 w-28 h-28 rounded-full opacity-40 animate-pulse pointer-events-none"
               style="background:radial-gradient(circle,#84cc16 0%,transparent 70%)"></div>
          <div class="absolute top-5 left-12 w-1.5 h-1.5 bg-white/40 rounded-full pointer-events-none"
               style="animation:float 4s ease-in-out infinite"></div>
          <div class="absolute top-12 left-6 w-1 h-1 bg-[#84cc16]/60 rounded-full pointer-events-none"
               style="animation:float 5s ease-in-out infinite 1s"></div>
          <div class="flex flex-col gap-1 max-w-[55%] relative z-10">
            <p class="text-white/50 text-xs font-semibold uppercase tracking-wide">مدرسك</p>
            <h3 class="font-black text-xl text-white leading-tight">{{ teacherName }}</h3>
            <p *ngIf="teacherSubject" class="text-white/60 text-xs">{{ teacherSubject }}</p>
            <p *ngIf="teacherQuote" class="text-white/50 text-xs italic mt-1 leading-relaxed line-clamp-2">"{{ teacherQuote }}"</p>
          </div>
          <div class="relative flex-shrink-0 z-10" style="margin-top:-3.5rem">
            <div class="absolute inset-0 rounded-full opacity-70 pointer-events-none"
                 style="background:radial-gradient(circle,#84cc16 30%,transparent 75%);transform:scale(1.15);filter:blur(4px)"></div>
            <div class="relative w-28 h-28 rounded-full overflow-hidden border-[3px] border-white shadow-2xl">
              <img *ngIf="teacherAvatar" [src]="teacherAvatar" alt="" class="w-full h-full object-cover object-top scale-110">
              <div *ngIf="!teacherAvatar" class="w-full h-full flex items-center justify-center bg-white/10">
                <span class="material-symbols-outlined text-white/70" style="font-size:48px">person</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ③ Social links bar (bottom) -->
      <div *ngIf="teacherHasSocials"
           class="flex items-center justify-center gap-2 bg-white dark:bg-[#162033] border-t border-[#DDE1EA] dark:border-slate-800 px-4 py-3 flex-shrink-0 flex-wrap">
        <a *ngIf="teacherYoutube" [href]="teacherYoutube" target="_blank" rel="noopener"
           class="w-9 h-9 rounded-xl flex items-center justify-center bg-red-50 dark:bg-red-900/20 hover:bg-red-100 transition-colors" title="يوتيوب">
          <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
        </a>
        <a *ngIf="teacherFacebook" [href]="teacherFacebook" target="_blank" rel="noopener"
           class="w-9 h-9 rounded-xl flex items-center justify-center bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 transition-colors" title="فيسبوك">
          <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.88v2.27h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
        </a>
        <a *ngIf="teacherInstagram" [href]="teacherInstagram" target="_blank" rel="noopener"
           class="w-9 h-9 rounded-xl flex items-center justify-center bg-pink-50 dark:bg-pink-900/20 hover:bg-pink-100 transition-colors" title="إنستغرام">
          <svg class="w-5 h-5 text-pink-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85 0 3.2-.01 3.58-.07 4.85-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07-3.2 0-3.58-.01-4.85-.07-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12c0-3.2.01-3.58.07-4.85C2.38 3.86 3.9 2.31 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 2.7.27.27 2.7.07 7.05.01 8.33 0 8.74 0 12c0 3.26.01 3.67.07 4.95.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24c3.26 0 3.67-.01 4.95-.07 4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95 0-3.26-.01-3.67-.07-4.95C23.73 2.71 21.31.27 16.95.07 15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32A6.16 6.16 0 0 0 12 5.84zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></svg>
        </a>
        <a *ngIf="teacherTiktok" [href]="teacherTiktok" target="_blank" rel="noopener"
           class="w-9 h-9 rounded-xl flex items-center justify-center bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 transition-colors" title="تيك توك">
          <svg class="w-5 h-5 text-gray-800 dark:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.27 8.27 0 0 0 4.84 1.55V6.78a4.85 4.85 0 0 1-1.07-.09z"/></svg>
        </a>
        <a *ngIf="teacherWhatsapp" [href]="'https://wa.me/' + teacherWhatsapp" target="_blank" rel="noopener"
           class="w-9 h-9 rounded-xl flex items-center justify-center bg-green-50 dark:bg-green-900/20 hover:bg-green-100 transition-colors" title="واتساب">
          <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.47-2.4-1.49-.89-.8-1.49-1.78-1.66-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.01-1.04 2.47s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.29.17-1.42-.07-.12-.27-.2-.57-.34z"/><path d="M12 0C5.37 0 0 5.37 0 12c0 2.12.55 4.11 1.52 5.84L0 24l6.33-1.49A11.94 11.94 0 0 0 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0zm0 21.82a9.77 9.77 0 0 1-5.01-1.38l-.36-.21-3.75.88.9-3.65-.23-.37A9.82 9.82 0 0 1 2.18 12C2.18 6.56 6.56 2.18 12 2.18S21.82 6.56 21.82 12 17.44 21.82 12 21.82z"/></svg>
        </a>
        <a *ngIf="teacherTelegram" [href]="teacherTelegram" target="_blank" rel="noopener"
           class="w-9 h-9 rounded-xl flex items-center justify-center bg-sky-50 dark:bg-sky-900/20 hover:bg-sky-100 transition-colors" title="تيليغرام">
          <svg class="w-5 h-5 text-sky-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.94 8.19-2.02 9.51c-.15.67-.54.83-1.1.52l-3-2.21-1.45 1.4c-.16.16-.3.3-.61.3l.22-3.07 5.6-5.06c.24-.22-.05-.34-.38-.12L6.6 14.39 3.64 13.5c-.66-.2-.67-.66.14-.98l11.62-4.48c.55-.2 1.03.13.54 2.15z"/></svg>
        </a>
      </div>
    </div>

  </div><!-- /hero grid -->

  <!-- ══ ROW 2: Featured Courses Carousel (left) + كورساتي (right) ══ -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

    <!-- AI Assistant — light card -->
    <a routerLink="/ai-chat"
       class="flex flex-col justify-between rounded-2xl p-6 cursor-pointer group relative overflow-hidden transition-all hover:shadow-lg hover:-translate-y-0.5"
       style="background:linear-gradient(135deg,#f0fdf9 0%,#e6f7f3 100%);border:1.5px solid #c8ede6;min-height:180px">
      <!-- Animated robot blobs -->
      <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-20 pointer-events-none"
           style="background:radial-gradient(circle,#4BBBA0,transparent);animation:pulse 3s ease-in-out infinite"></div>
      <div class="absolute -bottom-4 -left-4 w-16 h-16 rounded-full opacity-15 pointer-events-none"
           style="background:radial-gradient(circle,#183764,transparent);animation:pulse 4s ease-in-out infinite 1s"></div>

      <div class="relative z-10">
        <!-- Robot with animation -->
        <div class="flex items-center gap-3 mb-3">
          <div class="w-12 h-12 rounded-2xl bg-[#4BBBA0] flex items-center justify-center shadow-lg flex-shrink-0"
               style="animation:float 3s ease-in-out infinite">
            <span class="material-symbols-outlined text-white" style="font-size:26px;font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24">smart_toy</span>
          </div>
          <div>
            <h3 class="font-black text-xl text-[#183764] leading-tight">المساعد الذكي 🤖</h3>
            <p class="text-[#4BBBA0] text-xs font-semibold">مساعدك الشخصي في الدراسة</p>
          </div>
        </div>
        <!-- Animated chat bubbles preview -->
        <div class="space-y-1.5 mb-4">
          <div class="inline-flex items-center gap-2 bg-white/80 rounded-xl px-3 py-1.5 text-xs text-[#183764] font-medium shadow-sm">
            <span class="w-1.5 h-1.5 bg-[#4BBBA0] rounded-full animate-pulse"></span>
            يمكنك سؤالي عن أي شيء يخص دراستك
          </div>
        </div>
        <span class="inline-flex items-center gap-2 bg-[#4BBBA0] text-white px-5 py-2.5 rounded-xl font-bold text-sm group-hover:opacity-90 transition-all shadow-md">
          <span class="material-symbols-outlined" style="font-size:17px">chat</span>
          ابدأ المحادثة
        </span>
      </div>
    </a>

    <!-- Store Banner — dark navy with marquee -->
    <a routerLink="/store"
       class="flex flex-col justify-between rounded-2xl p-6 cursor-pointer group relative overflow-hidden transition-all hover:opacity-95"
       style="background:linear-gradient(145deg,#0d1b3e 0%,#183764 60%,#0d1b3e 100%);min-height:180px">
      <!-- Decorative lines -->
      <div class="absolute inset-0 opacity-5 pointer-events-none"
           style="background-image:repeating-linear-gradient(0deg,transparent,transparent 28px,rgba(255,255,255,.4) 28px,rgba(255,255,255,.4) 29px)"></div>
      <!-- Glow -->
      <div class="absolute top-0 right-0 w-40 h-40 rounded-full opacity-10 pointer-events-none"
           style="background:radial-gradient(circle,#F59239,transparent)"></div>

      <div cl