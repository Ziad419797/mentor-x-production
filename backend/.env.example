# ═══════════════════════════════════════════════════════════════════
#  EduCore — Production Environment Variables
#
#  ❌ لا ترفع هذا الملف على GitHub
#  ✅ انسخه وسمّيه .env وعبّي القيم الحقيقية
#  ✅ على السيرفر: اعمل export لكل variable دي
# ═══════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/educore
DB_USERNAME=postgres
DB_PASSWORD=1162004

# ─── Server ────────────────────────────────────────────────────────
PORT=8081
COOKIE_SECURE=true          # true في الـ production (HTTPS فقط)

# ─── JWT ───────────────────────────────────────────────────────────
# أنشئ secret قوي: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-here

# ─── CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ─── Admin ─────────────────────────────────────────────────────────
ADMIN_PHONE=01000000000
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_NAME=Super Admin

# ─── Support ───────────────────────────────────────────────────────
SUPPORT_WHATSAPP=+201234567890

# ─── Cloudinary (رفع الصور) ─────────────────────────────────────────
# اجيبهم من: cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── SMS Misr (OTP) ────────────────────────────────────────────────
# اجيبهم من: smsmisr.com/Client/Settings
SMS_PROVIDER=smsmisr          # غيّر من console لـ smsmisr في الـ production
SMSMISR_USERNAME=your-username
SMSMISR_PASSWORD=your-password
SMSMISR_SENDER=your-sender-token
SMSMISR_TEMPLATE=your-template-token
SMSMISR_ENV=1                 # 1=Live (production) | 2=Test

# ─── Fawaterek (دفع إلكتروني) ──────────────────────────────────────
# اجيبهم من: app.fawaterk.com/dashboard → Settings → API
FAWATEREK_API_KEY=your-fawaterek-api-key
FAWATEREK_SUCCESS_URL=https://your-frontend.com/payment/success
FAWATEREK_FAIL_URL=https://your-frontend.com/payment/fail
FAWATEREK_PENDING_URL=https://your-frontend.com/payment/pending
FAWATEREK_CALLBACK_URL=https://your-api.com/api/payment/fawaterek/callback
FAWATEREK_WEBHOOK_SECRET=your-webhook-secret-from-fawaterek-dashboard
